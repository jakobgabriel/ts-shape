{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "osvVulnerabilityAlerts": true,
  "minimumReleaseAge": "3 days",
  "prConcurrentLimit": 5,
  "assignees": ["jakobgabriel"],
  "commitMessagePrefix": "chore(deps):",
  "enabledManagers": [
    "pep621",
    "pip_requirements",
    "pip_setup",
    "github-actions",
    "python-version"
  ],
  "python": {
    "fileMatch": ["(^|/)pyproject\\.toml$"]
  },
  "schedule": ["before 9am on Monday"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 9am on Monday"]
  },
  "packageRules": [
    {
      "description": "Group core runtime dependencies",
      "matchManagers": ["pep621"],
      "matchDepTypes": ["dependencies"],
      "groupName": "core runtime dependencies"
    },
    {
      "description": "Group scientific stack (numpy, pandas, scipy)",
      "matchPackageNames": ["numpy", "pandas", "scipy"],
      "groupName": "scientific stack"
    },
    {
      "description": "Group cloud storage dependencies (azure-storage-blob, s3fs)",
      "matchPackageNames": ["azure-storage-blob", "s3fs"],
      "groupName": "cloud storage"
    },
    {
      "description": "Automerge docs dependencies (minor/patch)",
      "matchManagers": ["pip_requirements"],
      "matchFileNames": ["requirements-docs.txt"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "groupName": "docs dependencies"
    },
    {
      "description": "Automerge minor and patch updates",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Require manual review for major bumps",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["major-update"]
    },
    {
      "description": "Vulnerability fixes bypass schedule and get security label",
      "matchCategories": ["security"],
      "schedule": ["at any time"],
      "labels": ["security"],
      "automerge": false
    },
    {
      "description": "Pin and auto-update GitHub Actions by SHA digest",
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "automerge": true,
      "groupName": "github actions"
    }
  ]
}
